{
    "compilerOptions": {
        "target": "ES2016" /* Specify ECMAScript target version for transpiled JS. */,
        "module": "CommonJS" /* Specify module code generation (for Node.js). */,
        "outDir": "./dist" /* Redirect output structure to the 'dist' folder. */,
        "rootDir": "." /* Specify the root directory of input files. */,
        "strict": true /* Enable all strict type-checking options. */,
        "esModuleInterop": true /* Enables compatibility for default imports (e.g., from CommonJS). */,
        "skipLibCheck": true /* Skip type checking of declaration files. */,
        "forceConsistentCasingInFileNames": true /* Ensure that casing is consistent for imported modules. */
    },
    "include": ["**/*.ts"] /* Only compile files in the 'src' directory. */
}
